# ─── FilaZero / Trya Backend URLs ───────────────────────────────
# Leave empty to run in mock mode (default for development).

# trya-backend (NestJS — tenant API, journeys, validation, clinical data)
VITE_TRYA_BACKEND_URL=

# platform-backend (NestJS — admin, regulation, scheduling, analytics)
VITE_PLATFORM_BACKEND_URL=

# chat-backend HTTP (conversation management, REST endpoints)
VITE_CHAT_HTTP_URL=

# chat-backend WebSocket (real-time intake conversation)
VITE_CHAT_WS_URL=

# ─── AWS Cognito ────────────────────────────────────────────────
VITE_COGNITO_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=

# ─── Feature Flags ──────────────────────────────────────────────
# Global toggle (enables all backends when true)
VITE_ENABLE_REAL_BACKEND=false
VITE_ENABLE_REAL_AUTH=false
VITE_ENABLE_WEBSOCKET=false

# Granular backend flags (override global per service)
# Set to "true" to enable a specific backend while others stay mocked
VITE_ENABLE_REAL_TRYA=false
VITE_ENABLE_REAL_PLATFORM=false
VITE_ENABLE_REAL_CHAT=false
