# =============================================================================
# Account Configuration Template
# =============================================================================
# Copie este arquivo para a nova conta e ajuste os valores

locals {
  account_id   = "CHANGE_ME"  # AWS Account ID
  account_name = "CHANGE_ME"  # Ex: cliente-x-hml
  
  # Domínios
  domain     = "CHANGE_ME"  # Ex: hml.clientex.trya.ai
  api_domain = "CHANGE_ME"  # Ex: hml-api.clientex.trya.ai
  
  # Tier (standard, enterprise, premium)
  tier = "standard"
}
