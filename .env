# ─── trya-backend ────────────────────────────────────────────────
# Change this URL to point at any reachable backend:
#   http://localhost:3000          ← local dev
#   http://127.0.0.1:3000         ← local dev (alternative)
#   https://your-staging.com/v1   ← remote staging
VITE_TRYA_BACKEND_URL=http://localhost:3000
VITE_ENABLE_REAL_TRYA=true

# ─── Everything else stays OFF ───────────────────────────────────
VITE_PLATFORM_BACKEND_URL=
VITE_CHAT_HTTP_URL=
VITE_CHAT_WS_URL=
VITE_COGNITO_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_ENABLE_REAL_BACKEND=false
VITE_ENABLE_REAL_AUTH=false
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_REAL_PLATFORM=false
VITE_ENABLE_REAL_CHAT=false
