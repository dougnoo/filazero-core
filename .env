# ─── DEMO MODE ────────────────────────────────────────────────
# Set to true for live presentations. All services use mock data.
# No backend, no auth server, no API calls. Everything works offline.
VITE_DEMO_MODE=true

# ─── trya-backend ────────────────────────────────────────────────
VITE_TRYA_BACKEND_URL=
VITE_ENABLE_REAL_TRYA=false

# ─── Everything else stays OFF ───────────────────────────────────
VITE_PLATFORM_BACKEND_URL=
VITE_CHAT_HTTP_URL=
VITE_CHAT_WS_URL=
VITE_COGNITO_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_ENABLE_REAL_BACKEND=false
VITE_ENABLE_REAL_AUTH=false
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_REAL_PLATFORM=false
VITE_ENABLE_REAL_CHAT=false