# ============================================
# CONFIGURAÇÃO DE STORAGE (NOVO - Arquitetura Plugável)
# ============================================

# Opções: memory | redis | dynamodb | hybrid
# - memory: Desenvolvimento local (sem persistência)
# - redis: Cache rápido (requer Redis/ElastiCache)
# - dynamodb: Persistência durável (requer AWS)
# - hybrid: Cache + Persistência (RECOMENDADO para produção)
STORAGE_BACKEND=hybrid

# Redis/ElastiCache (quando usar 'redis' ou 'hybrid')
CACHE_ENDPOINT=localhost
CACHE_PORT=6379
CACHE_TTL=3600  # 1 hora (em segundos)

# ============================================
# AWS Configuration
# ============================================
# Para SSO, configure usando: aws configure sso
# Depois execute: aws sso login --profile seu-perfil
# O boto3 usará automaticamente as credenciais do SSO

AWS_REGION=us-east-1

# Opcional: se usar perfil SSO específico
# AWS_PROFILE=seu-perfil-sso

# ============================================
# AWS Bedrock
# ============================================
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# AWS Bedrock Knowledge Base (opcional)
# ID da Knowledge Base para consultas médicas
KNOWLEDGE_BASE_ID=sua-knowledge-base-id-aqui

# ============================================
# DynamoDB
# ============================================
SESSIONS_TABLE_NAME=triagem-sessions-dev
SESSION_TTL_HOURS=168

CONNECTIONS_TABLE=triagem-connections-dev

# ============================================
# S3
# ============================================
BUCKET_NAME=triagem-ia

# ============================================
# Integração Trya
# ============================================
# URL base da API Trya (sem barra final)
TRYA_API_PLATFORM_URL=https://api.trya.com.br

# Chave de API para autenticação
TRYA_API_PLATFORM_KEY=sua-api-key-aqui

# ============================================
# API do Tenant (Onboarding)
# ============================================
# URL da API do tenant para envio de dados de onboarding
TENANT_API_URL=https://api.tenant.com/onboarding

# Chave de API para autenticação
TENANT_API_KEY=sua-tenant-api-key-aqui

# ============================================
# EXEMPLOS POR AMBIENTE
# ============================================

# DESENVOLVIMENTO LOCAL:
# STORAGE_BACKEND=memory

# DESENVOLVIMENTO COM DOCKER REDIS:
# STORAGE_BACKEND=redis
# CACHE_ENDPOINT=localhost

# STAGING/PRODUÇÃO:
# STORAGE_BACKEND=hybrid
# CACHE_ENDPOINT=my-redis.cache.amazonaws.com
# SESSIONS_TABLE_NAME=triagem-sessions-prod
