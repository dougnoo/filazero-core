# API Configuration
# Backend Trya - auth, termos, etc.
# Local: http://localhost:3001 | Dev: https://dev-api.trya.ai
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Platform API (médicos, receitas)
NEXT_PUBLIC_PLATFORM_API_BASE_URL=http://localhost:3001

# S3 Assets Configuration
# URL base for static assets (images, logos, backgrounds)
# DEV: https://trya-assets-dev.s3.us-east-1.amazonaws.com
# HML: https://trya-assets-hml.s3.us-east-1.amazonaws.com
# PROD: https://trya-assets-prod.s3.us-east-1.amazonaws.com
NEXT_PUBLIC_ASSETS_S3_URL=https://trya-assets-dev.s3.us-east-1.amazonaws.com
