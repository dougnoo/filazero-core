# =============================================================================
# Backend com LocalStack - Copie para .env ou adicione ao .env existente
# =============================================================================
# Após subir o LocalStack: docker-compose -f docker-compose.local.yml up -d
# Aguarde ~30s e execute: source ../localstack-data/config.env (ou copie os valores)
# =============================================================================

# LocalStack endpoint (obrigatório)
AWS_ENDPOINT_URL=http://localhost:4566

# Cognito (valores gerados pelo init - ver localstack-data/config.env após init)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_REGION=us-east-1

# S3
S3_BUCKET_NAME=trya-terms-local
S3_BUCKET_REGION=us-east-1

# Credenciais para LocalStack (fixas)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# DynamoDB (opcional - OTP em memory por padrão)
# OTP_STORAGE=memory
DYNAMODB_SESSIONS_TABLE=triagem-sessions
DYNAMODB_OTP_TABLE_NAME=trya-otp
DYNAMODB_CONFIG_TABLE=trya-config

# CORS para frontend local
CORS_ORIGIN=http://localhost:3000
