# Application Configuration
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:3000
TRYA_PLATFORM_API_KEY=your-trya-platform-api-key
TRYA_PLATFORM_API_URL=base-url-of-trya-platform-api

# JWT Configuration
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# AWS General Configuration
AWS_REGION=us-east-1

# Configuração de AWS SSO (RECOMENDADO para desenvolvimento)
# Passo 1: Faça login no AWS SSO
#   aws sso login --profile AWSPowerUserAccess-416684166863
# Passo 2: Configure o profile no seu .env:
AWS_PROFILE=AWSPowerUserAccess-416684166863
# Passo 3: Listar profiles disponíveis: aws configure list-profiles

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=your-cognito-domain
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback

# OTP Storage Configuration
# Options: "memory" (default, dev only) or "dynamodb" (production)
# Para começar sem AWS, use "memory"
OTP_STORAGE=memory

# DynamoDB Configuration (required if OTP_STORAGE=dynamodb)
DYNAMODB_OTP_TABLE_NAME=trya-otp

# Notification Service Configuration
# Options: "console" (default, dev only) or "ses" (production)
# Para começar sem AWS, use "console"
NOTIFICATION_SERVICE=console

# AWS SES Configuration (required if NOTIFICATION_SERVICE=ses)
SES_FROM_EMAIL=noreply@trya.health
SES_FROM_NAME=HandsLab

# AWS Credentials (ALTERNATIVA - não necessário se usar AWS SSO)
# Se você NÃO está usando AWS SSO, descomente as linhas abaixo:
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# AWS Bucket Configuration
S3_BUCKET_REGION=us-east-1
S3_BUCKET_CHAT_NAME=triagem-saude-dev
S3_BUCKET_NAME=broker-tenant-1

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=handslab_trya
# TypeORM connection URL (used by data-source.ts)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# AWS Lambda Configuration
LAMBDA_CHAT_FUNCTION_NAME=lambda-dev

# DynamoDB Tables Configuration
DYNAMODB_SESSIONS_TABLE=triagem-sessions-dev

# ElastiCache (Redis)
ELASTICACHE_HOST=your-elasticache-endpoint.cache.amazonaws.com
ELASTICACHE_PORT=6379
ELASTICACHE_TLS=true

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Amil API Configuration
AMIL_API_BASE_URL=https://www.amil.com.br/portalbeneficiario/buscacredenciado

# Encryption Key for sensitive data
ENCRYPTION_KEY=secreto1234567890

# Tenant-specific Chat API Key
TENANT_CHAT_API_KEY=your-tenant-chat-api-key