# Application settings
NODE_ENV=development
PORT=3000

AWS_RUNTIME=local
AWS_REGION=us-east-1
AWS_PROFILE=default

AWS_AGENT_ID=agent-id-placeholder
AWS_AGENT_ALIAS_ID=agent-alias-id-placeholder

BEDROCK_REQUESTS_PER_MINUTE=4

TRANSCRIBE_BUCKET_NAME=bucket-name-placeholder
TRANSCRIBE_LANGUAGE_CODE=pt-BR
TRANSCRIBE_ENABLE_SPEAKER_LABELS=false
TRANSCRIBE_MAX_ALTERNATIVES=2
TRANSCRIBE_TIMEOUT_MS=30000


# Multi-Tenant AWS Configuration

# Tenant 1 - Operadora ABC
AWS_AGENT_ID_TENANT_1=agent-id-tenant-1
AWS_AGENT_ALIAS_ID_TENANT_1=agent-alias-id-tenant-1

# Tenant 2 - Operadora XYZ
AWS_AGENT_ID_TENANT_2=agent-id-tenant-2
AWS_AGENT_ALIAS_ID_TENANT_2=agent-alias-id-tenant-2














