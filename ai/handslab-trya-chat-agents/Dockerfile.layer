# Configuração do Docker para criar layer das dependências
# Use este Dockerfile para criar um Lambda Layer com as dependências

FROM public.ecr.aws/lambda/python:3.11

# Copia requirements
COPY requirements.txt .

# Instala dependências no diretório correto para Lambda Layer
RUN pip install -r requirements.txt -t /opt/python/

# O layer deve estar em /opt/python para ser reconhecido pela Lambda
CMD ["/bin/bash"]
