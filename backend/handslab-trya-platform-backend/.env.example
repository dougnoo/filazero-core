# AWS Configuration
# AWS region where your Cognito User Pool is located (e.g., us-east-1, sa-east-1)
AWS_REGION=us-east-1

# AWS Profile (optional - for AWS SSO or named profiles in ~/.aws/config)
# If set, the SDK will use this profile instead of access keys
# Leave empty to use default credential chain (SSO, env vars, IAM role, etc)
AWS_PROFILE=

# AWS IAM credentials (optional if using AWS_PROFILE or SSO)
# These credentials should have cognito-idp:* permissions
# Only required if not using AWS SSO or IAM roles
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Cognito Configuration
# User Pool ID from AWS Cognito console (format: region_xxxxxxxxx)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# App Client ID from your Cognito User Pool
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# App Client Secret (required if your App Client has a secret configured)
# Get this from AWS Cognito console → User Pool → App Integration → App clients
COGNITO_CLIENT_SECRET=

# JWT Configuration
# Secret key used to sign JWT tokens (use a strong random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# JWT token expiration time in seconds (default: 3600 = 1 hour)
JWT_EXPIRATION=3600

# Database Configuration (PostgreSQL)
# Database host (use 'localhost' for local development, service name for Docker)
DB_HOST=localhost

# Database port (default PostgreSQL port is 5432)
DB_PORT=5432

# Database name
DB_NAME=trya_platform

# Database schema (default: platform_dev for development, platform_prod for production)
DB_SCHEMA=platform_dev

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=postgres

# Application Configuration
# Port where the NestJS application will run
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# CORS Configuration
# Allowed origin for CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Allow credentials in CORS requests
CORS_CREDENTIALS=true

# Notification Configuration
# Notification service: 'console' for development, 'ses' for production
NOTIFICATION_SERVICE=console

# Frontend URL for email links (e.g., login page)
FRONTEND_URL=http://localhost:3000/login

# OTP Configuration
# DynamoDB table name for OTP codes
DYNAMODB_OTP_TABLE_NAME=platform-otp-codes

# AWS SES Configuration (optional - only required if NOTIFICATION_SERVICE=ses)
# Email address to send notifications from (must be verified in AWS SES)
AWS_SES_FROM_EMAIL=noreply@trya.com.br

# Display name for email sender
AWS_SES_FROM_NAME=Trya

# AWS S3 Configuration
# S3 bucket name for storing profile pictures and other files
AWS_S3_BUCKET_NAME=trya-platform-assets

# Tenant bucket suffix for multi-environment support
# Production: leave empty
# Staging/HML: -sa
# Dev: -dev
TENANT_BUCKET_SUFFIX=-sa

# Trya assets bucket (overrides default broker-tenant-1)
TRYA_ASSETS_BUCKET=broker-tenant-1-hml

# Bucket region mapping (optional, JSON format)
# Example: {"grupotrigo-assets-sa":"sa-east-1","broker-tenant-1-hml":"us-east-1"}
BUCKET_REGION_MAP={"grupotrigo-assets-sa":"sa-east-1"}

# Integration API Key
# API Key for external integrations (e.g., Trya Backend)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRYA_PLATFORM_API_KEY=your-api-key-change-this-in-production
# Memed Integration Configuration
# API Key for Memed prescription service
# Get this from Memed dashboard (sandbox or production)
MEMED_API_KEY=iJGiB4kjDGOLeDFPWMG3no9VnN7Abpqe3w1jEFm6olkhkZD6oSfSmYCm

# Secret Key for Memed API authentication
MEMED_SECRET_KEY=Xe8M5GvBGCr4FStKfxXKisRo3SfYKI7KrTMkJpCAstzu2yXVN4av5nmL

# Memed environment (sandbox or production)
MEMED_ENVIRONMENT=sandbox

# Bucket Configuration
TENANT_BUCKET_SUFFIX=-sa
TRYA_ASSETS_BUCKET=broker-tenant-1-hml
BUCKET_REGION_MAP={"grupotrigo-assets-sa":"sa-east-1"}

# CDN Configuration
ASSETS_CDN_URL=https://hml-app.trya.ai

# Google Places API Configuration
# API Key for Google Places API (Text Search + Place Details)
# Get from: https://console.cloud.google.com/apis/credentials
# Required APIs: Places API (New)
# Cost: ~$0.032 per Text Search request + $0.017 per Place Details request
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
