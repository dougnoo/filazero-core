{
  "name": "handslab-trya-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm:migration:generate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:generate src/database/migrations/initial -d src/database/data-source.ts",
    "typeorm:migration:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "typeorm:migration:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "seed:tenants": "ts-node -r tsconfig-paths/register src/database/seeds/seed-tenants.ts",
    "seed:chronic-conditions": "ts-node -r tsconfig-paths/register src/database/seeds/seed-chronic-conditions.ts",
    "seed:medications": "ts-node -r tsconfig-paths/register src/database/seeds/seed-medications.ts",
    "seed:health-operators": "ts-node -r tsconfig-paths/register src/database/seeds/seed-health-operators.ts",
    "seed:health-plans": "ts-node -r tsconfig-paths/register src/database/seeds/seed-health-plans.ts",
    "seed:initial-config": "ts-node -r tsconfig-paths/register src/database/seeds/seed-initial-config.ts",
    "seed:tutorials": "ts-node -r tsconfig-paths/register src/database/seeds/seed-tutorials.ts",
    "seed:dev-users": "ts-node -r tsconfig-paths/register src/database/seeds/seed-dev-users.ts",
    "seed:fix-tenant-id": "ts-node -r tsconfig-paths/register src/database/seeds/fix-users-tenant-id.ts",
    "seed:all": "npm run seed:tenants && npm run seed:chronic-conditions && npm run seed:medications && npm run seed:health-operators && npm run seed:health-plans && npm run seed:initial-config && npm run seed:tutorials && npm run seed:dev-users"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.941.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.914.0",
    "@aws-sdk/client-dynamodb": "^3.914.0",
    "@aws-sdk/client-lambda": "^3.935.0",
    "@aws-sdk/client-s3": "^3.917.0",
    "@aws-sdk/client-ses": "^3.914.0",
    "@aws-sdk/credential-provider-node": "^3.972.14",
    "@aws-sdk/lib-dynamodb": "^3.914.0",
    "@aws-sdk/s3-request-presigner": "^3.937.0",
    "@napi-rs/canvas": "^0.1.83",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.9",
    "@opensearch-project/opensearch": "^3.5.1",
    "@types/cheerio": "^1.0.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.449",
    "pg": "^8.13.1",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuidv7": "^1.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
